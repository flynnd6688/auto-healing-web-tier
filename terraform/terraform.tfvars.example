# Copy this file to terraform.tfvars and adjust values as needed.
# Do NOT commit terraform.tfvars if it contains sensitive data.

aws_region   = "ap-southeast-2"
project_name = "auto-healing-web"
environment  = "dev"

instance_type    = "t3.micro"
desired_capacity = 2
min_size         = 2
max_size         = 4

# Replace with your GitHub Container Registry image after pushing:
docker_image = "ghcr.io/OWNER/auto-healing-web:latest"
